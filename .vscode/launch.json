    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Run UDP Gateway",
            "request": "launch",
            "mainClass": "ufrn.imd.br.gateway.APIGateway",
            "args": ["udp"]
        },
        {
            "type": "java",
            "name": "Run TCP Gateway",
            "request": "launch",
            "mainClass": "ufrn.imd.br.gateway.APIGateway",
            "args": ["tcp"]
        },
        {
            "type": "java",
            "name": "Run UDP Client",
            "request": "launch",
            "mainClass": "ufrn.imd.br.client.UDPClient",
        },
        {
            "type": "java",
            "name": "Run UDP Messages 1",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["udp", "messages", "1"]
        },
        {
            "type": "java",
            "name": "Run UDP Messages 2",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["udp", "messages", "2"]
        },
        {
            "type": "java",
            "name": "Run UDP Users 1",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["udp", "users", "1"]
        },
        {
            "type": "java",
            "name": "Run UDP Users 2",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["udp", "users", "2"]
        },
        {
            "type": "java",
            "name": "Run TCP Messages 1",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["tcp", "messages", "1"]
        },
        {
            "type": "java",
            "name": "Run TCP Messages 2",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["tcp", "messages", "2"]
        },
        {
            "type": "java",
            "name": "Run TCP Users 1",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["tcp", "users", "1"]
        },
        {
            "type": "java",
            "name": "Run TCP Users 2",
            "request": "launch",
            "mainClass": "ufrn.imd.br.server.Application",
            "args": ["tcp", "users", "2"]
        }
    ]
